Bootstrap: docker
From: python:3.12-slim

# Tesseract floorplan->graph environment as ONE .sif file (inode-frugal: a
# containerized baseline costs ~1 file on project storage vs ~50k for a conda env).
# Tesseract CODE + weights stay on disk and are bind-mounted at run time; this
# image holds only the Python environment.

%post
    set -e
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential libglib2.0-0 libgl1 libgomp1 git wget && \
        rm -rf /var/lib/apt/lists/*
    pip install --no-cache-dir torch torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cpu
    pip install --no-cache-dir numpy opencv-python-headless Pillow pandas matplotlib \
        networkx scikit-image lmdb natsort six python-Levenshtein fuzzywuzzy \
        fastapi "uvicorn[standard]" python-multipart huggingface_hub

%test
    python -c "import torch, cv2, skimage, lmdb; print('tesseract container OK', torch.__version__)"

%labels
    Project TopoField
    Purpose Tesseract floorplan->graph extraction (raster-lane backbone)
